// Nextflow configuration for MPB_SNP_GATK pipeline
// Edit params.work_dir below to point to your scratch space before running.

params {
    work_dir = "/scratch/<your-username>/SNP_calling/work"   // <-- update this
}

workDir = params.work_dir

process {
    executor = 'slurm'
    cpus     = 4
    memory   = '64 GB'
    time     = '20h'
}

singularity {
    enabled = false
}

timeline {
    enabled = true
    file    = "timeline.html"
}

trace {
    enabled = true
    file    = "trace.txt"
}

report {
    enabled = true
    file    = "report.html"
}
